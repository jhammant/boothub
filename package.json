  "devDependencies": {
    "@types/aws-lambda": "^8.10.150",
    "@types/node": "^22.10.0",
    "aws-cdk": "^2.176.0",
    "aws-cdk-lib": "^2.176.0",
    "constructs": "^10.4.2",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
